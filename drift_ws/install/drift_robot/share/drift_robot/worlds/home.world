    <model name="r1_base_west"><static>true</static><pose>-5.9 0 0.06 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>0.04 6.8 0.12</size></box></geometry><material><ambient>0.92 0.92 0.90 1</ambient><diffuse>0.96 0.96 0.94 1</diffuse><specular>0.18 0.18 0.16 1</specular></material></visual></link></model>
