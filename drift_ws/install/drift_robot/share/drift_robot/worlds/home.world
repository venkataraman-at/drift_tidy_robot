          <material>
            <ambient>0.95 0.80 0.05 1</ambient>
            <diffuse>0.98 0.84 0.06 1</diffuse>
            <specular>0.35 0.28 0.04 1</specular>
          </material>
        </visual>

        <!-- ── East wall (right) ── -->
        <collision name="wall_e_col">
          <pose>0.58 0 0.255 0 0 0</pose>
          <geometry><box><size>0.04 1.00 0.45</size></box></geometry>
        </collision>
