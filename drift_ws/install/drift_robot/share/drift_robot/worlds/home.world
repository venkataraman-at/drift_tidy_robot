        <collision name="leg_br_col"><pose>-0.19 -0.19 0.22 0 0 0</pose><geometry><cylinder><radius>0.025</radius><length>0.44</length></cylinder></geometry></collision>
        <visual name="leg_br_vis"><pose>-0.19 -0.19 0.22 0 0 0</pose><geometry><cylinder><radius>0.025</radius><length>0.44</length></cylinder></geometry><material><ambient>0.30 0.18 0.06 1</ambient><diffuse>0.30 0.18 0.06 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Chair 2 — west of table, facing east (+x) -->
    <model name="room1_chair2">
      <static>true</static><pose>-3.5 1.2 0 0 0 1.5708</pose>
      <link name="link">
