    <model name="r2_base_east"><static>true</static><pose>9.9 0 0.06 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>0.04 6.8 0.12</size></box></geometry><material><ambient>0.90 0.92 0.90 1</ambient><diffuse>0.94 0.96 0.94 1</diffuse><specular>0.18 0.18 0.18 1</specular></material></visual></link></model>

    <!-- ==================== ROOM 1 FURNITURE ==================== -->

    <!-- Dining table — centre (−2, 1.2) -->
    <model name="room1_table">
      <static>true</static><pose>-2 1.2 0 0 0 0</pose>
      <link name="link">
        <collision name="top_col"><pose>0 0 0.76 0 0 0</pose><geometry><box><size>1.4 0.75 0.04</size></box></geometry></collision>
        <visual name="top_vis"><pose>0 0 0.76 0 0 0</pose><geometry><box><size>1.4 0.75 0.04</size></box></geometry><material><ambient>0.48 0.30 0.12 1</ambient><diffuse>0.52 0.33 0.14 1</diffuse><specular>0.15 0.10 0.06 1</specular></material></visual>
        <visual name="apron_f"><pose>0 -0.345 0.695 0 0 0</pose><geometry><box><size>1.32 0.03 0.08</size></box></geometry><material><ambient>0.42 0.26 0.10 1</ambient><diffuse>0.42 0.26 0.10 1</diffuse></material></visual>
        <visual name="apron_b"><pose>0 0.345 0.695 0 0 0</pose><geometry><box><size>1.32 0.03 0.08</size></box></geometry><material><ambient>0.42 0.26 0.10 1</ambient><diffuse>0.42 0.26 0.10 1</diffuse></material></visual>
        <visual name="apron_l"><pose>-0.665 0 0.695 0 0 0</pose><geometry><box><size>0.03 0.69 0.08</size></box></geometry><material><ambient>0.42 0.26 0.10 1</ambient><diffuse>0.42 0.26 0.10 1</diffuse></material></visual>
        <visual name="apron_r"><pose>0.665 0 0.695 0 0 0</pose><geometry><box><size>0.03 0.69 0.08</size></box></geometry><material><ambient>0.42 0.26 0.10 1</ambient><diffuse>0.42 0.26 0.10 1</diffuse></material></visual>
        <collision name="leg_fl_col"><pose>-0.625 -0.32 0.365 0 0 0</pose><geometry><box><size>0.05 0.05 0.73</size></box></geometry></collision>
        <visual name="leg_fl_vis"><pose>-0.625 -0.32 0.365 0 0 0</pose><geometry><box><size>0.05 0.05 0.73</size></box></geometry><material><ambient>0.38 0.24 0.09 1</ambient><diffuse>0.38 0.24 0.09 1</diffuse></material></visual>
        <collision name="leg_fr_col"><pose>0.625 -0.32 0.365 0 0 0</pose><geometry><box><size>0.05 0.05 0.73</size></box></geometry></collision>
        <visual name="leg_fr_vis"><pose>0.625 -0.32 0.365 0 0 0</pose><geometry><box><size>0.05 0.05 0.73</size></box></geometry><material><ambient>0.38 0.24 0.09 1</ambient><diffuse>0.38 0.24 0.09 1</diffuse></material></visual>
