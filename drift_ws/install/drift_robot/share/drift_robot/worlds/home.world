        <!-- ── Corner cap reinforcements (visual only, adds solidity) ── -->
        <visual name="corner_sw">
          <pose>-0.56 -0.46 0.255 0 0 0</pose>
          <geometry><box><size>0.08 0.08 0.45</size></box></geometry>
