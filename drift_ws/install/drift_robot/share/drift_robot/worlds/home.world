    <!-- East wall — dusty slate-blue accent -->
    <model name="room2_wall_east">
      <static>true</static><pose>10 0 1.3 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 7 2.6</size></box></geometry><surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.2 7 2.6</size></box></geometry>
          <material><ambient>0.52 0.58 0.68 1</ambient><diffuse>0.58 0.65 0.76 1</diffuse><specular>0.04 0.04 0.05 1</specular><emissive>0.005 0.006 0.008 1</emissive></material></visual>
      </link>
    </model>

    <!-- ==================== BASEBOARDS ==================== -->

    <model name="r1_base_south"><static>true</static><pose>-2 -3.4 0.06 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>7.8 0.04 0.12</size></box></geometry><material><ambient>0.92 0.92 0.90 1</ambient><diffuse>0.96 0.96 0.94 1</diffuse><specular>0.18 0.18 0.16 1</specular></material></visual></link></model>
