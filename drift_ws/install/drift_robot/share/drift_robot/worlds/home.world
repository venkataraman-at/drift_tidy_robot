    <!-- ==================== PICKUP OBJECTS ==================== -->
    <!--
      12 objects placed strategically to constrain the robot's navigation path.
      Furniture footprints create corridors; objects are placed at the ends of those
      corridors, in corners, and in zones the robot must specifically detour into.

      ROOM 1 objects (6) — x=[-6,2], y=[-3.5,3.5]:
        1.  Red ball       (−4.5,  2.8)  NW corner, past west wall — behind chair2 line
        2.  Blue cube      ( 0.8,  2.5)  NE zone near shared wall, north side
        3.  Green cylinder (−5.2, −2.2)  Deep SW, tight corridor between west wall & sofa
        4.  White ball     (−0.5,  0.5)  Mid-east open corridor between table & doorway
        5.  Teal block     (−4.0, −1.0)  Mid-west, forces route around sofa left arm
        6.  Metal sphere   (−1.5,  3.1)  Near north wall, behind TV cabinet right side

      ROOM 2 objects (6) — x=[2,10], y=[-3.5,3.5]:
        7.  Yellow sphere  ( 3.5,  2.8)  NW of Room 2, near north wall
        8.  Orange cube    ( 5.5, −3.0)  Deep south, near south wall
        9.  Purple cyl     ( 6.8,  0.8)  Centre-west, between open floor & bed footboard
       10.  Magenta disc   ( 7.8, −2.5)  South zone, between bed footboard and south wall
       11.  Cyan tall cyl  ( 3.2, −1.5)  West side R2, narrow strip near doorway side
       12.  Pink book box  ( 5.0,  2.8)  North zone near north wall, under desk area

      Inertia tensors:
        Sphere  (r, m):      Ixx=Iyy=Izz = 2/5*m*r²
        Cylinder (r,l, m):  Ixx=Iyy = m*(3r²+l²)/12   Izz = m*r²/2
        Box (a,b,c, m):     Ixx = m*(b²+c²)/12   Iyy = m*(a²+c²)/12   Izz = m*(a²+b²)/12
    -->

    <!-- 1. Red ball — NW corner Room 1, behind chair2 line (−4.5, 2.8)
         Represents: bouncy toy ball.  r=0.05 m=0.10  I=2/5*0.10*0.0025=0.0001 -->
    <model name="pickup_ball_red"><static>false</static>
      <pose>-4.5 2.8 0.05 0 0 0</pose>
      <link name="link">
        <inertial><mass>0.10</mass><inertia><ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0001</iyy><iyz>0</iyz><izz>0.0001</izz></inertia></inertial>
        <collision name="col"><geometry><sphere><radius>0.05</radius></sphere></geometry>
          <surface><friction><ode><mu>0.60</mu><mu2>0.60</mu2></ode></friction><bounce><restitution_coefficient>0.65</restitution_coefficient><threshold>0.1</threshold></bounce></surface></collision>
        <visual name="vis"><geometry><sphere><radius>0.05</radius></sphere></geometry>
          <material><ambient>0.85 0.10 0.08 1</ambient><diffuse>0.92 0.12 0.08 1</diffuse><specular>0.40 0.10 0.10 1</specular></material></visual>
      </link>
    </model>

    <!-- 2. Blue cube — NE corner Room 1, near shared wall (0.8, 2.5)
         Represents: small wooden toy block.  0.08³ m=0.15  I=0.15*(0.08²+0.08²)/12=0.00016 -->
    <model name="pickup_cube_blue"><static>false</static>
      <pose>0.8 2.5 0.04 0 0 0.52</pose>
      <link name="link">
        <inertial><mass>0.15</mass><inertia><ixx>0.000160</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000160</iyy><iyz>0</iyz><izz>0.000160</izz></inertia></inertial>
        <collision name="col"><geometry><box><size>0.08 0.08 0.08</size></box></geometry>
          <surface><friction><ode><mu>0.80</mu><mu2>0.80</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.08 0.08 0.08</size></box></geometry>
          <material><ambient>0.10 0.18 0.82 1</ambient><diffuse>0.12 0.20 0.90 1</diffuse><specular>0.20 0.20 0.50 1</specular></material></visual>
      </link>
    </model>

    <!-- 3. Green cylinder — SW zone Room 1, south of sofa left arm (−4.5, −3.0)
         Represents: small drinks can.  r=0.04 l=0.12 m=0.14
         Ixx=Iyy=0.14*(3*0.0016+0.0144)/12=0.14*0.0192/12=0.0002240  Izz=0.14*0.0016/2=0.000112 -->
    <model name="pickup_cylinder_green"><static>false</static>
      <pose>-4.5 -3.0 0.06 0 0 0</pose>
      <link name="link">
        <inertial><mass>0.14</mass><inertia><ixx>0.000224</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000224</iyy><iyz>0</iyz><izz>0.000112</izz></inertia></inertial>
        <collision name="col"><geometry><cylinder><radius>0.04</radius><length>0.12</length></cylinder></geometry>
          <surface><friction><ode><mu>0.75</mu><mu2>0.75</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><cylinder><radius>0.04</radius><length>0.12</length></cylinder></geometry>
          <material><ambient>0.08 0.72 0.12 1</ambient><diffuse>0.10 0.82 0.14 1</diffuse><specular>0.10 0.40 0.15 1</specular></material></visual>
      </link>
    </model>

    <!-- 4. White ball — mid-east corridor Room 1, between table & doorway (−0.5, 0.5)
         Represents: tennis ball.  r=0.033 m=0.058  I=2/5*0.058*0.001089=0.0000252 -->
    <model name="pickup_ball_white"><static>false</static>
      <pose>-0.5 0.5 0.033 0 0 0</pose>
      <link name="link">
        <inertial><mass>0.058</mass><inertia><ixx>0.0000252</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0000252</iyy><iyz>0</iyz><izz>0.0000252</izz></inertia></inertial>
        <collision name="col"><geometry><sphere><radius>0.033</radius></sphere></geometry>
          <surface><friction><ode><mu>0.50</mu><mu2>0.50</mu2></ode></friction><bounce><restitution_coefficient>0.75</restitution_coefficient><threshold>0.05</threshold></bounce></surface></collision>
        <visual name="vis"><geometry><sphere><radius>0.033</radius></sphere></geometry>
          <material><ambient>0.92 0.92 0.88 1</ambient><diffuse>0.96 0.96 0.90 1</diffuse><specular>0.30 0.30 0.28 1</specular></material></visual>
      </link>
    </model>

    <!-- 5. Teal block — mid-west Room 1, west of sofa left arm (−4.0, −1.0)
         Represents: rectangular eraser / small flat object.
         0.14×0.07×0.04 m=0.22
         Ixx=0.22*(0.07²+0.04²)/12=0.22*0.0065/12=0.000119
         Iyy=0.22*(0.14²+0.04²)/12=0.22*0.0212/12=0.000389
         Izz=0.22*(0.14²+0.07²)/12=0.22*0.0245/12=0.000449 -->
    <model name="pickup_block_teal"><static>false</static>
      <pose>-4.0 -1.0 0.02 0 0 0.9</pose>
      <link name="link">
        <inertial><mass>0.22</mass><inertia><ixx>0.000119</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000389</iyy><iyz>0</iyz><izz>0.000449</izz></inertia></inertial>
        <collision name="col"><geometry><box><size>0.14 0.07 0.04</size></box></geometry>
          <surface><friction><ode><mu>0.72</mu><mu2>0.72</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.14 0.07 0.04</size></box></geometry>
          <material><ambient>0.08 0.62 0.60 1</ambient><diffuse>0.10 0.72 0.68 1</diffuse><specular>0.20 0.40 0.40 1</specular></material></visual>
      </link>
    </model>

    <!-- 6. Metal sphere — near north wall behind TV cabinet, Room 1 (−1.5, 3.1)
         Represents: heavy steel ball / door stopper.  r=0.04 m=0.50  I=2/5*0.50*0.0016=0.000320 -->
