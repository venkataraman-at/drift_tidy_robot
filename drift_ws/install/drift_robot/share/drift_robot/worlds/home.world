<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="home_world">

    <!-- ==================== PHYSICS ==================== -->
    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>50</iters>
          <sor>1.3</sor>
          <use_dynamic_moi_rescaling>true</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>100</contact_max_correcting_vel>
          <contact_surface_layer>0.001</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <!-- ==================== SCENE ==================== -->
    <scene>
      <ambient>0.35 0.35 0.35 1</ambient>
      <background>0.65 0.65 0.68 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
    </scene>

    <!-- ==================== LIGHTING ==================== -->
    <!-- Room 1 = WARM (amber/orange tones). Room 2 = COOL (blue/slate tones). -->

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.85 0.82 0.75 1</diffuse>
      <specular>0.30 0.28 0.25 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- WARM overhead — Room 1 -->
    <light type="point" name="room1_overhead">
      <pose>-2 0 2.4 0 0 0</pose>
      <diffuse>0.55 0.48 0.38 1</diffuse>
      <specular>0.18 0.15 0.10 1</specular>
      <attenuation><range>15</range><constant>0.4</constant><linear>0.02</linear><quadratic>0.002</quadratic></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- WARM accent — beside sofa, Room 1 -->
    <light type="point" name="room1_accent">
      <pose>-0.95 -2.84 1.85 0 0 0</pose>
      <diffuse>0.65 0.50 0.30 1</diffuse>
      <specular>0.20 0.15 0.08 1</specular>
      <attenuation><range>6</range><constant>0.5</constant><linear>0.08</linear><quadratic>0.02</quadratic></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- COOL overhead — Room 2 -->
    <light type="point" name="room2_overhead">
      <pose>6 0 2.4 0 0 0</pose>
      <diffuse>0.40 0.45 0.55 1</diffuse>
      <specular>0.12 0.14 0.18 1</specular>
      <attenuation><range>15</range><constant>0.4</constant><linear>0.02</linear><quadratic>0.002</quadratic></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- COOL accent — beside bed, Room 2 -->
    <light type="point" name="room2_accent">
      <pose>9.55 1.55 1.85 0 0 0</pose>
      <diffuse>0.42 0.48 0.60 1</diffuse>
      <specular>0.14 0.16 0.20 1</specular>
      <attenuation><range>5</range><constant>0.5</constant><linear>0.10</linear><quadratic>0.025</quadratic></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- WARM bedside — Room 2 (warm contrast against cool room tone) -->
    <light type="point" name="room2_bedside">
      <pose>8.8 -1.05 1.0 0 0 0</pose>
      <diffuse>0.68 0.52 0.30 1</diffuse>
      <specular>0.20 0.15 0.08 1</specular>
      <attenuation><range>4</range><constant>0.5</constant><linear>0.12</linear><quadratic>0.04</quadratic></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- ==================== PLUGINS ==================== -->
    <plugin filename="libgazebo_ros_state.so" name="gazebo_ros_state"/>
    <plugin name="gazebo_link_attacher" filename="libgazebo_link_attacher.so"/>

    <!-- ==================== GROUND PLANE ==================== -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="col">
          <geometry><plane><normal>0 0 1</normal><size>60 60</size></plane></geometry>
          <surface><friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction><contact><ode><min_depth>0.001</min_depth></ode></contact></surface>
        </collision>
        <visual name="vis">
          <geometry><plane><normal>0 0 1</normal><size>60 60</size></plane></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.65 0.65 0.65 1</diffuse><specular>0.08 0.08 0.08 1</specular></material>
        </visual>
      </link>
    </model>

    <!-- ==================== FLOOR TILES ==================== -->

    <!-- Room 1 — warm oak hardwood -->
    <model name="room1_floor">
      <static>true</static><pose>-2 0 0.001 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>8 7 0.002</size></box></geometry>
          <material><ambient>0.38 0.26 0.14 1</ambient><diffuse>0.58 0.40 0.22 1</diffuse><specular>0.22 0.16 0.09 1</specular><emissive>0.010 0.008 0.004 1</emissive></material>
        </visual>
      </link>
    </model>

    <!-- Room 2 — cool polished concrete -->
    <model name="room2_floor">
      <static>true</static><pose>6 0 0.001 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>8 7 0.002</size></box></geometry>
          <material><ambient>0.52 0.53 0.56 1</ambient><diffuse>0.68 0.69 0.72 1</diffuse><specular>0.30 0.30 0.32 1</specular><emissive>0.005 0.005 0.006 1</emissive></material>
        </visual>
      </link>
    </model>

    <!-- ==================== ROOM 1 WALLS ==================== -->
    <!-- Room 1: 8×7 m, centre (−2,0), x=[−6,2], y=[−3.5,3.5], h=2.6 m -->

    <model name="room1_wall_south">
      <static>true</static><pose>-2 -3.5 1.3 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>8.4 0.2 2.6</size></box></geometry><surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>8.4 0.2 2.6</size></box></geometry>
          <material><ambient>0.82 0.78 0.70 1</ambient><diffuse>0.91 0.87 0.79 1</diffuse><specular>0.04 0.04 0.03 1</specular><emissive>0.008 0.007 0.005 1</emissive></material></visual>
      </link>
    </model>

    <model name="room1_wall_north">
      <static>true</static><pose>-2 3.5 1.3 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>8.4 0.2 2.6</size></box></geometry><surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>8.4 0.2 2.6</size></box></geometry>
          <material><ambient>0.82 0.78 0.70 1</ambient><diffuse>0.91 0.87 0.79 1</diffuse><specular>0.04 0.04 0.03 1</specular><emissive>0.008 0.007 0.005 1</emissive></material></visual>
      </link>
    </model>

    <!-- West wall — terracotta accent -->
    <model name="room1_wall_west">
      <static>true</static><pose>-6 0 1.3 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 7 2.6</size></box></geometry><surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.2 7 2.6</size></box></geometry>
          <material><ambient>0.68 0.54 0.42 1</ambient><diffuse>0.76 0.61 0.48 1</diffuse><specular>0.04 0.03 0.02 1</specular><emissive>0.006 0.005 0.003 1</emissive></material></visual>
      </link>
    </model>

    <!-- Shared wall — doorway at y=0, 1.2 m wide -->
    <model name="shared_wall_south">
      <static>true</static><pose>2 -2.15 1.3 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 2.9 2.6</size></box></geometry><surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.2 2.9 2.6</size></box></geometry>
          <material><ambient>0.74 0.72 0.68 1</ambient><diffuse>0.83 0.81 0.76 1</diffuse><specular>0.05 0.05 0.04 1</specular></material></visual>
      </link>
    </model>

    <model name="shared_wall_north">
      <static>true</static><pose>2 2.15 1.3 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 2.9 2.6</size></box></geometry><surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.2 2.9 2.6</size></box></geometry>
          <material><ambient>0.74 0.72 0.68 1</ambient><diffuse>0.83 0.81 0.76 1</diffuse><specular>0.05 0.05 0.04 1</specular></material></visual>
      </link>
    </model>

    <model name="doorway_lintel">
      <static>true</static><pose>2 0 2.325 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.2 1.2 0.55</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.2 1.2 0.55</size></box></geometry>
          <material><ambient>0.80 0.76 0.70 1</ambient><diffuse>0.88 0.84 0.77 1</diffuse><specular>0.04 0.04 0.03 1</specular></material></visual>
      </link>
    </model>

    <model name="door_frame_left">
      <static>true</static><pose>2 -0.62 1.025 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><box><size>0.22 0.06 2.05</size></box></geometry>
          <material><ambient>0.75 0.62 0.42 1</ambient><diffuse>0.75 0.62 0.42 1</diffuse><specular>0.12 0.10 0.07 1</specular></material></visual>
      </link>
    </model>

    <model name="door_frame_right">
      <static>true</static><pose>2 0.62 1.025 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><box><size>0.22 0.06 2.05</size></box></geometry>
          <material><ambient>0.75 0.62 0.42 1</ambient><diffuse>0.75 0.62 0.42 1</diffuse><specular>0.12 0.10 0.07 1</specular></material></visual>
      </link>
    </model>

    <model name="door_frame_top">
      <static>true</static><pose>2 0 2.075 0 0 0</pose>
      <link name="link">
        <visual name="vis"><geometry><box><size>0.22 1.24 0.06</size></box></geometry>
          <material><ambient>0.75 0.62 0.42 1</ambient><diffuse>0.75 0.62 0.42 1</diffuse><specular>0.12 0.10 0.07 1</specular></material></visual>
      </link>
    </model>

    <!-- ==================== ROOM 2 WALLS ==================== -->
    <!-- Room 2: 8×7 m, centre (6,0), x=[2,10], y=[−3.5,3.5], h=2.6 m -->

    <model name="room2_wall_south">
      <static>true</static><pose>6 -3.5 1.3 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>8.4 0.2 2.6</size></box></geometry><surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction></surface></collision>
