    <!-- ==================== COLLECTION BOX ==================== -->
    <!--
      ==================== COLLECTION BOX (large) ====================
      Dimensions: 1.2 m (x) × 1.0 m (y) × 0.45 m wall height.
      Position:   (−5.0, −2.5) — SW corner of Room 1, far from doorway.
      This corner is the largest unobstructed open floor area in Room 1:
        • West wall inner face at x = −5.9
        • South wall inner face at y = −3.4
        • Sofa right arm ends at x ≈ −1.14 — over 2.5 m clearance to the east
        • Robot can approach from any direction through the open centre of Room 1
      Box centre sits ~0.9 m from both walls so it doesn't touch the baseboard.
      Bright yellow with bold black label band facing east (into the room).
    -->
    <model name="collection_box">
      <static>true</static>
      <pose>-5.0 -2.5 0 0 0 0</pose>
      <link name="link">

        <!-- ── Floor ── -->
        <collision name="floor_col">
          <pose>0 0 0.015 0 0 0</pose>
          <geometry><box><size>1.20 1.00 0.030</size></box></geometry>
        </collision>
        <visual name="floor_vis">
          <pose>0 0 0.015 0 0 0</pose>
          <geometry><box><size>1.20 1.00 0.030</size></box></geometry>
          <material>
            <ambient>0.95 0.80 0.05 1</ambient>
            <diffuse>0.98 0.84 0.06 1</diffuse>
            <specular>0.35 0.28 0.04 1</specular>
          </material>
        </visual>

        <!-- ── South wall (front, facing robot start) ── -->
        <collision name="wall_s_col">
          <pose>0 -0.48 0.255 0 0 0</pose>
          <geometry><box><size>1.20 0.04 0.45</size></box></geometry>
        </collision>
        <visual name="wall_s_vis">
          <pose>0 -0.48 0.255 0 0 0</pose>
          <geometry><box><size>1.20 0.04 0.45</size></box></geometry>
          <material>
            <ambient>0.95 0.80 0.05 1</ambient>
            <diffuse>0.98 0.84 0.06 1</diffuse>
            <specular>0.35 0.28 0.04 1</specular>
          </material>
        </visual>

        <!-- ── North wall (back) ── -->
        <collision name="wall_n_col">
          <pose>0 0.48 0.255 0 0 0</pose>
          <geometry><box><size>1.20 0.04 0.45</size></box></geometry>
        </collision>
        <visual name="wall_n_vis">
          <pose>0 0.48 0.255 0 0 0</pose>
          <geometry><box><size>1.20 0.04 0.45</size></box></geometry>
          <material>
            <ambient>0.95 0.80 0.05 1</ambient>
            <diffuse>0.98 0.84 0.06 1</diffuse>
            <specular>0.35 0.28 0.04 1</specular>
          </material>
        </visual>

        <!-- ── West wall (left) ── -->
        <collision name="wall_w_col">
          <pose>-0.58 0 0.255 0 0 0</pose>
          <geometry><box><size>0.04 1.00 0.45</size></box></geometry>
        </collision>
