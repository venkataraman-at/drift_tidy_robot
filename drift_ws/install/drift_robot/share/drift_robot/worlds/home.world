        <collision name="leg_br_col"><pose>0.625 0.32 0.365 0 0 0</pose><geometry><box><size>0.05 0.05 0.73</size></box></geometry></collision>
        <visual name="leg_br_vis"><pose>0.625 0.32 0.365 0 0 0</pose><geometry><box><size>0.05 0.05 0.73</size></box></geometry><material><ambient>0.38 0.24 0.09 1</ambient><diffuse>0.38 0.24 0.09 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Chair 1 — south of table, facing north (+y) -->
    <model name="room1_chair1">
      <static>true</static><pose>-2 0.55 0 0 0 0</pose>
      <link name="link">
        <collision name="seat_col"><pose>0 0 0.46 0 0 0</pose><geometry><box><size>0.44 0.44 0.06</size></box></geometry></collision>
